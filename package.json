{
  "name": "agent-jam",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "agent": "tsx scripts/run-agent.ts",
    "agent:jazz": "tsx scripts/run-agent.ts --style jazz --name 'Jazz Bot'",
    "agent:ambient": "tsx scripts/run-agent.ts --style ambient --name 'Ambient Bot'",
    "agent:funk": "tsx scripts/run-agent.ts --style funk --name 'Funk Bot'",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "immer": "^10.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tone": "^15.1.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.0",
    "@cloudflare/workers-types": "^4.20250310.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.0.0"
  }
}
