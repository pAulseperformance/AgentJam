{
  "name": "agent-jam",
  "main": "src/server/index.ts",
  "compatibility_date": "2024-04-10",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "JAM_ROOM",
        "class_name": "JamRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["JamRoom"]
    }
  ],
  "ai": {
    "binding": "AI"
  }
}
